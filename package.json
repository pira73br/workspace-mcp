{
  "name": "workspace-mcp",
  "version": "0.1.0",
  "description": "Generic secure local MCP platform for authorized development workspaces",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "workspace-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "minimatch": "10.0.1",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/minimatch": "5.1.2",
    "@types/node": "22.13.10",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "vitest": "3.0.9"
  }
}
